                    (item.location && item.location.toLowerCase().includes(searchTerm)) ||
                    (item.type && item.type.toLowerCase().includes(searchTerm)) ||
                    (item.subcategory && item.subcategory.toLowerCase().includes(searchTerm));

                const matchCategory = !category || item.category === category;
                
                const matchSubcategory = !subcategory || item.subcategory === subcategory;

                const matchLocation = !location || 
                    (location === 'מקוון' && item.location_type === 'מקוון') ||
                    (item.location && item.location.includes(location)) ||
                    (location === 'כל הארץ' && (item.location.includes('כל הארץ') || item.location.includes('פריסה ארצית')));

                return matchSearch && matchCategory && matchSubcategory && matchLocation;
            });

            updateDisplay();
        }

        // עדכון התצוגה
        function updateDisplay() {
            updateStats();
            renderCards();
        }

        // עדכון הסטטיסטיקות
        function updateStats() {
            const stats = document.getElementById('stats');
            const onlineCount = filteredData.filter(item => item.location_type === 'מקוון').length;
            const physicalCount = filteredData.filter(item => item.location_type === 'פיזי').length;
            
            stats.innerHTML = `
                <div class="stat-item">📊 סה"כ: ${filteredData.length} מקומות</div>
                <div class="stat-item">💻 מקוון: ${onlineCount}</div>
                <div class="stat-item">📍 פיזי: ${physicalCount}</div>
            `;
        }

        // רינדור הכרטיסים
        function renderCards() {
            const container = document.getElementById('cards');

            if (filteredData.length === 0) {
                container.innerHTML = '<div class="no-results">😔 לא נמצאו תוצאות מתאימות. נסו לשנות את הסינון.</div>';
                return;
            }

            container.innerHTML = filteredData.map(item => `
                <div class="card">
                    <div class="card-badges">
                        <span class="badge badge-category">${item.category}</span>
                        ${item.subcategory ? `<span class="badge badge-subcategory">${item.subcategory}</span>` : ''}
                        ${item.location_type === 'מקוון' ? '<span class="badge badge-online">💻 מקוון</span>' : ''}
                    </div>

                    <div class="card-header">
                        <div class="card-title">${item.name}</div>
                    </div>

                    <div class="card-body">
                        ${item.type ? `<div class="card-info"><strong>סוג:</strong><span>${item.type}</span></div>` : ''}
                        ${item.location ? `<div class="card-info"><strong>📍 מיקום:</strong><span>${item.location}</span></div>` : ''}
                        ${item.address ? `<div class="card-info"><strong>כתובת:</strong><span>${item.address}</span></div>` : ''}
                        ${item.contact ? `<div class="card-info"><strong>👤 איש קשר:</strong><span>${item.contact}</span></div>` : ''}
                        ${item.phone ? `<div class="card-info"><strong>📞 טלפון:</strong><span dir="ltr">${item.phone}</span></div>` : ''}
                        ${item.description ? `<div class="card-description">${item.description}</div>` : ''}
                    </div>

                    <div class="card-footer">
                        ${item.email && item.email !== 'nan' && item.email !== '' ? `<a href="mailto:${item.email}" class="contact-btn">✉️ שלח מייל</a>` : ''}
                        ${item.website && item.website !== 'nan' && item.website !== '' ? `<a href="${item.website}" target="_blank" class="website-btn">🌐 אתר</a>` : ''}
                        ${item.phone && item.phone !== 'nan' && item.phone !== '' ? `<a href="tel:${item.phone.replace(/\\n/g, ',').replace(/\\\\/g, ',')}" class="contact-btn">📞 התקשר</a>` : ''}
                    </div>
                </div>
            `).join('');
        }

        // איפוס הסינון
        function resetFilters() {
            document.getElementById('search').value = '';
            document.getElementById('category').value = '';
            document.getElementById('subcategory').value = '';
            document.getElementById('location').value = '';
            document.querySelectorAll('.quick-filter-btn').forEach(btn => btn.classList.remove('active'));
            filterData();
        }

        // Event listeners
        document.getElementById('search').addEventListener('input', filterData);
        document.getElementById('category').addEventListener('change', filterData);
        document.getElementById('subcategory').addEventListener('change', filterData);
        document.getElementById('location').addEventListener('change', filterData);

        // טעינה ראשונית
        init();
    </script>
</body>
</html>
